
import { NextResponse } from "next/server"
import { createClient } from "@/lib/supabase/server"

export async function GET(request: Request) {
  try {
    const { searchParams } = new URL(request.url)
    const timeRange = searchParams.get("timeRange") || "24h"

    const supabase = await createClient()

    const {
      data: { user },
      error: authError,
    } = await supabase.auth.getUser()

    if (authError || !user) {
      return NextResponse.json({ error: "Unauthorized" }, { status: 401 })
    }

    const { data: devices, error: deviceError } = await supabase
      .from("devices")
      .select("id, last_heartbeat")
      .eq("user_id", user.id)

    if (deviceError) {
      console.error("[v0] Error fetching devices for PoP:", deviceError)
      return NextResponse.json({ error: "Failed to fetch devices" }, { status: 500 })
    }

    const now = new Date()
    const ninetySecondsAgo = new Date(now.getTime() - 90 * 1000)
    const onlineDeviceIds = new Set<string>()

    if (devices) {
      devices.forEach((device) => {
        const lastHeartbeat = device.last_heartbeat ? new Date(device.last_heartbeat) : null
        if (lastHeartbeat && lastHeartbeat > ninetySecondsAgo) {
          onlineDeviceIds.add(device.id)
        }
      })
    }

    let startDate = new Date()
    switch (timeRange) {
      case "7d":
        startDate = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000)
        break
      case "30d":
        startDate = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000)
        break
      default: // 24h
        startDate = new Date(now.getTime() - 24 * 60 * 60 * 1000)
        break
    }

    const { data: events, error: eventsError } = await supabase
      .from("device_events")
      .select("device_id, event_type")
      .eq("user_id", user.id)
      .gte("created_at", startDate.toISOString())

    if (eventsError) {
      console.error("[v0] Error fetching proof of play events:", eventsError)
      return NextResponse.json({ error: "Failed to fetch events" }, { status: 500 })
    }

    let onlinePlays = 0
    let offlinePlays = 0
    let totalStartedPlays = 0
    let totalCompletedPlays = 0

    if (events) {
      for (const event of events) {
        if (event.event_type === "media_start") {
          totalStartedPlays++
        } else if (event.event_type === "media_end") {
          if (event.device_id && onlineDeviceIds.has(event.device_id)) {
            onlinePlays++
          } else {
            offlinePlays++
          }
        }
      }
    }

    totalCompletedPlays = onlinePlays + offlinePlays
    const successRate = totalStartedPlays > 0 ? ((totalCompletedPlays / totalStartedPlays) * 100).toFixed(0) : "0"

    return NextResponse.json({
      summary: {
        online_plays: onlinePlays,
        offline_plays: offlinePlays,
        total_plays: totalCompletedPlays,
        completed_plays: totalCompletedPlays,
        success_rate: successRate,
      },
      top_media: [],
      timeline: [],
      recent_events: [],
      time_range: timeRange,
    })
  } catch (error) {
    console.error("[v0] Proof of play stats API error:", error)
    return NextResponse.json({ error: "Internal server error" }, { status: 500 })
  }
}
